# InTrades Environment Variables
# Copy to .env and fill in your values

# -----------------------------------------------------------------------------
# AI APIs
# -----------------------------------------------------------------------------
VITE_ANTHROPIC_API_KEY=
VITE_DEEPSEEK_API_KEY=
VITE_GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Supabase Configuration (Database & Auth)
# -----------------------------------------------------------------------------
# Found in Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Database Configuration (Local / Railway)
# -----------------------------------------------------------------------------
# Local: postgresql://postgres:postgres@localhost:5432/intrades
# Railway: provided in your Railway DB settings panel
DATABASE_URL=

# -----------------------------------------------------------------------------
# Redis Configuration (Local / Railway)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Vercel Configuration
# -----------------------------------------------------------------------------
VITE_APP_URL=http://localhost:5173
NODE_ENV=development
